# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=videotree

# ── Auth ───────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=your_admin_password

# ── Public URL (REQUIRED) ──────────────────────────────────────────────────────
# The public-facing domain of your site — used to build /uploads/ image URLs.
# Without this, uploaded images will use internal hostnames and won't load.
# Example: https://videotree.co.in
PUBLIC_URL=https://videotree.co.in

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
